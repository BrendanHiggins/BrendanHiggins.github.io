<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{ title }}</title>
    <meta name="description" content="{{ description or "brendanhiggins.dev" }}">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.colors.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@picocss/pico@2/css/pico.jade.min.css">
    <link rel="stylesheet" href="/css/style.css">
   
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@24,400,0,0" />
    <link href="https://fonts.googleapis.com/css2?family=Google+Sans+Code:ital,wght@0,300..800;1,300..800&family=Google+Sans+Flex:opsz,wght@6..144,1..1000&display=swap" rel="stylesheet">
    
    <script src="https://kit.fontawesome.com/c66265a3dd.js" crossorigin="anonymous"></script>
    
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png">
    <link rel="apple-touch-icon" href="/favicon.png">

    <script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
</head>
<body>

    <header class="container">
        <nav>
            <ul>
                <li>
                    <i class="fa-solid fa-caret-right sitename-color"></i>
                    <strong><a id="#top" href="/" class="contrast sitename-color">brendanhiggins.dev</a></strong>
                </li>
            </ul>
            <ul>
                <li><a href="/" data-tooltip="Home" data-placement="bottom" aria-label="Home"><i class="fa-solid fa-house"></i></a></li>
                <li>
                    <a href="#" id="random-post-btn" data-tooltip="Random Post" data-placement="bottom" aria-label="Random Post" onclick="goToRandomPost(event)">
                        <i class="fa-solid fa-shuffle"></i>
                    </a>
                </li>
                <li><a href="/about" data-tooltip="About" data-placement="bottom" aria-label="About"><i class="fa-solid fa-circle-info"></i></a></li>
                <li><a href="/search" data-tooltip="Search" data-placement="bottom" aria-label="Search"><i class="fa-solid fa-magnifying-glass"></i></a></li>
            </ul>
        </nav>
    </header>

    <main class="container no-bottom-padding">
        {{ content | safe }}
    </main>

    <footer class="container">
        <hr class="hr-no-theme"/>
        <small><em>It is not the critic who counts.</em></small>
        <small>© 2025 brendanhiggins.dev</small>
    </footer>

    <script>
        const ALL_POST_URLS = [
            {% for post in collections.posts %}
                "{{ post.url }}",
            {% endfor %}
        ];

        function goToRandomPost(e) {
            if (e) e.preventDefault();
            if (!ALL_POST_URLS || ALL_POST_URLS.length === 0) return;
            const currentPath = window.location.pathname.replace(/\/$/, '');
            const availablePosts = ALL_POST_URLS.filter(url => url.replace(/\/$/, '') !== currentPath);
            const pool = availablePosts.length > 0 ? availablePosts : ALL_POST_URLS;
            const randomIndex = Math.floor(Math.random() * pool.length);
            window.location.href = pool[randomIndex];
        }
    </script>

</body>
</html>